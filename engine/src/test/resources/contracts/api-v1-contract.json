{
  "version": "1",
  "paths": {
    "/v1": ["get"],
    "/v1/info": ["get"],
    "/v1/processes": ["get"],
    "/v1/processes/deploy": ["post"],
    "/v1/processes/start": ["post"],
    "/v1/processes/instances": ["get"],
    "/v1/processes/instances/{instanceId}": ["get"],
    "/v1/processes/instance/{id}/fail": ["post"],
    "/v1/processes/{id}": ["get"],
    "/v1/tasks": ["get"],
    "/v1/tasks/{id}": ["get"],
    "/v1/tasks/claim": ["post"],
    "/v1/tasks/unclaim": ["post"],
    "/v1/tasks/complete": ["post"],
    "/v1/tasks/fail": ["post"],
    "/v1/tasks/user-stats": ["get"],
    "/v1/process-instances/{instanceId}/variables": ["get", "patch"],
    "/v1/process-instances/{id}": ["delete"],
    "/v1/process-instances/{id}/suspension": ["put"],
    "/v1/process-instances/{id}/activity-instances": ["get"],
    "/v1/process-instances/{id}/history": ["get"],
    "/v1/jobs": ["get"],
    "/v1/jobs/{jobId}/retries": ["post"],
    "/v1/jobs/{jobId}/stacktrace": ["get"],
    "/v1/events/messages": ["post"],
    "/v1/events/signals": ["post"],
    "/v1/external-tasks/fetch-and-lock": ["post"],
    "/v1/external-tasks/{id}/complete": ["post"],
    "/v1/external-tasks/{id}/failure": ["post"],
    "/v1/external-tasks/{id}/extend-lock": ["post"],
    "/v1/external-tasks/{id}/heartbeat": ["post"],
    "/v1/external-tasks/{id}/bpmn-error": ["post"]
  },
  "schemas": [
    "ApiError",
    "DeploymentResponse",
    "ProcessDefinitionDto",
    "ProcessInstanceDTO",
    "ProcessStartResponse",
    "ProcessActionResponse",
    "TaskDetailsDto",
    "TaskActionResponse",
    "FetchAndLockRequest",
    "LockedExternalTask",
    "CompleteExternalTaskRequest",
    "ExternalTaskFailureDto",
    "ExternalTaskBpmnErrorRequest",
    "ExtendLockRequest",
    "ActivityHistoryDto",
    "FailedJobDTO"
  ],
  "schemaProperties": {
    "ApiError": ["timestamp", "status", "code", "message", "path", "traceId", "details"],
    "DeploymentResponse": ["status", "processDefinitionId", "deploymentId", "version", "definitionFormatVersion", "compatibilityProfiles", "compatibilityReport"],
    "ProcessDefinitionDto": ["id", "name", "documentation", "bpmnXml", "deploymentId", "version", "createdAt"],
    "ProcessInstanceDTO": ["id", "processDefinitionId", "processDefinitionName", "currentActivityId", "status", "suspended", "startDate", "endDate", "startedBy", "variables"],
    "ProcessStartResponse": ["processInstanceId"],
    "ProcessActionResponse": ["status", "processInstanceId"],
    "TaskDetailsDto": ["id", "taskDefinitionKey", "name", "assignee", "status", "startDate", "endDate", "candidateUsers", "candidateGroups", "processInstanceId", "processDefinitionId", "processDefinitionName", "processStatus", "processSuspended", "processStartDate", "processEndDate", "currentActivityId", "variables"],
    "TaskActionResponse": ["status", "taskId"],
    "FetchAndLockRequest": ["workerId", "topics", "lockDuration", "maxTasks"],
    "LockedExternalTask": ["id", "topicName", "variables", "processInstanceId", "activityId", "retries", "lockExpirationTime", "traceParent", "protocolVersion"],
    "CompleteExternalTaskRequest": ["workerId", "variables"],
    "ExternalTaskFailureDto": ["workerId", "errorMessage", "errorDetails", "retries", "retryTimeout"],
    "ExternalTaskBpmnErrorRequest": ["workerId", "errorCode", "errorMessage", "variables"],
    "ExtendLockRequest": ["workerId", "lockDuration"],
    "ActivityHistoryDto": ["id", "processInstanceId", "processDefinitionId", "activityId", "eventType", "actor", "occurredAt", "traceId", "details"],
    "FailedJobDTO": ["jobId", "processInstanceId", "activityId", "exceptionMessage", "retries"]
  }
}
